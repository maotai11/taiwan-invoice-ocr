{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taiwan Invoice OCR",
  "version": "0.2.0",
  "identifier": "com.lin.taiwan-invoice-ocr",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Taiwan Invoice OCR",
        "width": 1200,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../scripts/ocr_pipeline.py": "scripts/ocr_pipeline.py",
      "../scripts/invoice_classifier.py": "scripts/invoice_classifier.py",
      "../config/ocr_config.json": "config/ocr_config.json",
      "../config/keyword_weights.json": "config/keyword_weights.json",
      "../ocr_models/det": "ocr_models/det",
      "../ocr_models/rec": "ocr_models/rec",
      "../ocr_models/cls": "ocr_models/cls"
    }
  }
}
